{
  "name": "@aily-ui/core",
  "version": "0.1.0",
  "description": "aily-ui design system 聚合包 · 一行 import 全套组件 (类 antd) · 跨端 (Web + RN)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./style.css": "./src/style.css"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "lucide-react": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "lucide-react-native": { "optional": true },
    "react-native-svg": { "optional": true }
  },
  "dependencies": {
    "@aily-ui/tokens": "github:yarnovo/aily-ui-tokens",
    "@aily-ui/icons": "github:yarnovo/aily-ui-icons",
    "@aily-ui/button": "github:yarnovo/aily-ui-button",
    "@aily-ui/bottom-nav": "github:yarnovo/aily-ui-bottom-nav",
    "@aily-ui/avatar": "github:yarnovo/aily-ui-avatar",
    "@aily-ui/lazy-image": "github:yarnovo/aily-ui-lazy-image",
    "@aily-ui/skeleton": "github:yarnovo/aily-ui-skeleton",
    "@aily-ui/chat-bubble": "github:yarnovo/aily-ui-chat-bubble",
    "@aily-ui/chat-input": "github:yarnovo/aily-ui-chat-input",
    "@aily-ui/typing-indicator": "github:yarnovo/aily-ui-typing-indicator",
    "@aily-ui/conversation-item": "github:yarnovo/aily-ui-conversation-item",
    "@aily-ui/chat-layout": "github:yarnovo/aily-ui-chat-layout",
    "@aily-ui/auth-login": "github:yarnovo/aily-ui-auth-login"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "^0.85.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": { "access": "public" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yarnovo/aily-ui-core.git"
